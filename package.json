{
  "name": "@kaelith-labs/cli",
  "version": "0.3.1",
  "description": "Vibe Coding Framework MCP server + CLI — LLM-agnostic lifecycle tooling (capture, spec, plan, build, test, review, ship).",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Vibe Coding Framework contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kaelith-Labs/vcf-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Kaelith-Labs/vcf-cli/issues"
  },
  "homepage": "https://github.com/Kaelith-Labs/vcf-cli#readme",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "vcf": "dist/cli.js",
    "vcf-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "templates",
    "skills",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "pino": "^9.5.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.6.1",
    "zod": "^4.0.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "peerDependencies": {
    "@kaelith-labs/kb": ">=0.0.1-alpha <0.2.0"
  },
  "peerDependenciesMeta": {
    "@kaelith-labs/kb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
